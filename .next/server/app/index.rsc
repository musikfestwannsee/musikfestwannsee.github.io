1f:["$","div",null,{"ref":"$undefined","className":"p-6 bg-beige","children":[["$","h4",null,{"className":"text-xl font-bold text-slate-800 dark:text-white mb-1","children":["In Zusammenarbeit mit der Evangelischen Kirchengemeinde Berlin-Wannsee",["$","br",null,{}],"und der Kirche St. Peter und Paul auf Nikolskoe",["$","br",null,{}]]}],["$","p",null,{"className":"text-sm font-medium text-slate-600 dark:text-slate-300 mb-3","children":["Sapna Joshi, Pfarrerin der Ev. Gemeinde Berlin-Wannsee",["$","br",null,{}],"Ute Hagmayer, Pfarrerin von St. Peter und Paul auf Nikolskoe"]}]]}]
