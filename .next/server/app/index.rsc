1b:["$","div",null,{"className":"grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-16","children":[["$","div","0",{"ref":"$undefined","className":"rounded-sm border border-border text-card-foreground overflow-hidden bg-beige-50 border-none shadow-lg hover:shadow-xl transition-shadow","children":[["$","div",null,{"className":"aspect-square relative","children":["$","$L6",null,{"src":"artists/Shimon_Yoshida.png","alt":"Shimon Yoshida","fill":true,"className":"object-cover"}]}],["$","div",null,{"ref":"$undefined","className":"p-6 dark:bg-slate-800","children":[["$","h2",null,{"className":"text-xl font-display mb-2 handwritten-first-letter group-hover:opacity-0","children":"Shimon Yoshida"}],["$","h4",null,{"className":"text-l text-sky-700 font-display mb-2 group-hover:opacity-0","children":"Tenor"}],["$","div",null,{"children":[["$","p","0",{"className":"text-sm font-medium mb-3","children":["Shimon Yoshida wurde 1992 in Nagoya (Japan) geboren und absolvierte sein Masterstudium (Konzertgesang) an der Hochschule für Musik und Theater München bei Prof. Sylvia Greenberg.",["$","br",null,{}]]}],["$","p","1",{"className":"text-sm font-medium mb-3","children":["2022 hat Shimon Yoshida unter Leitung von René Jacobs Bachs h-Moll-Messe als Einspringer des Tenorsolisten gesungen. Oktober 2023 hat er für erkrankten Tenorsolist kurzfristig die Partie von Rossinis Stabat Mater übernommen (Philharmonie Berlin, Großersaal).",["$","br",null,{}]]}],["$","p","2",{"className":"text-sm font-medium mb-3","children":["Bei dem renommierten Bach Collegium Japan unter der Leitung von Masaaki Suzuki ist er seit 2022 regelmäßiger Gast. April 2024 gab er seinen US-Debüt als Solist (Bachs h-Moll Messe) in Boston.",["$","br",null,{}]]}],["$","p","3",{"className":"text-sm font-medium mb-3","children":["Seit März 2020 ist Shimon Yoshida festes Mitglied bei RIAS Kammerchor Berlin.",["$","br",null,{}]]}],["$","p","4",{"className":"text-sm font-medium mb-3","children":["Mit seiner Familie wohnt er in Berlin.",["$","br",null,{}]]}]]}]]}]]}],["$","div","1",{"ref":"$undefined","className":"rounded-sm border border-border text-card-foreground overflow-hidden bg-beige-50 border-none shadow-lg hover:shadow-xl transition-shadow","children":[["$","div",null,{"className":"aspect-square relative","children":["$","$L6",null,{"src":"artists/Thorsten_Kaldewei.png","alt":"Thorsten Kaldewei","fill":true,"className":"object-cover"}]}],["$","div",null,{"ref":"$undefined","className":"p-6 dark:bg-slate-800","children":[["$","h2",null,{"className":"text-xl font-display mb-2 handwritten-first-letter group-hover:opacity-0","children":"Thorsten Kaldewei"}],["$","h4",null,{"className":"text-l text-sky-700 font-display mb-2 group-hover:opacity-0","children":"Pianist"}],["$","div",null,{"children":[["$","p","0",{"className":"text-sm font-medium mb-3","children":["Der Pianist Thorsten Kaldewei ist Dozent für Repertoire und Liedgestaltung an der Universität der Künste Berlin. Er studierte Klavier und Liedgestaltung an der Musikhochschule Köln, u.a. bei Prof. Michael Endres. Bei Rudolf Jansen und Irwin Gage erhielt er weitere wichtige Anregungen für sein Liedrepertoire.",["$","br",null,{}]]}],["$","p","1",{"className":"text-sm font-medium mb-3","children":["Als Solorepetitor arbeitete er an den Staatsopern Hannover und Stuttgart sowie an der Komischen Oper Berlin. Darüber hinaus ist seine pianistische Tätigkeit vielfältig: Konzerte mit Chören und Orchestern, wie z.B. dem RIAS Kammerchor, Kammermusik, Liederabende, Uraufführungen sowie Rundfunk- und CD- Produktionen. Wichtige Stationen seiner künstlerischen Laufbahn waren u.a. Auftritte in der Tonhalle Düsseldorf, der Stuttgarter Liederhalle und in der Berliner Philharmonie. Weiterhin führten ihn Konzertreisen durch halb Europa sowie in die USA und Südkorea. Im Rahmen seiner Konzerttätigkeit arbeitete er mit Sängern wie u.a. Ute Lemper, Gisela May, Dagmar Schellenberger und Julie Kaufmann.","$L2a"]}],"$L2b","$L2c"]}]]}]]}],"$L2d","$L2e","$L2f"]}]
