1d:["$","div","2",{"className":"text-center","children":[["$","div",null,{"className":"aspect-square bg-muted rounded-sm overflow-hidden mb-6 elegant-border","style":{"backgroundImage":"url(locations/Andreas_Kirche.png)","backgroundSize":"cover","backgroundPosition":"center"}}],["$","div",null,{"className":"flex-grow","children":[["$","h2",null,{"className":"text-xl font-display mb-2 handwritten-first-letter","children":"Andreaskirche"}],["$","p",null,{"className":"text-sm text-amber-50 mb-4 lg:min-h-[200px] min-h-[300px]","children":"Lassen Sie sich begeistern durch dieses Kleinod in neugotischem Stil. Diese, 1896, ohne auffälligen Prunk gebaute Kirche bildet zusammen mit der zuvor begonnenen Anlage des Friedhofs und der ursprünglich als Aussegnungshalle geschaffenen Vorhalle ein in Berlin einzigartiges Ensemble."}]]}],["$","div",null,{"children":[["$","h4",null,{"className":"text-l font-display mb-2 handwritten-first-letter","children":"Anfahrt"}],["$","p",null,{"className":"text-sm text-amber-50 mb-4","children":"Lindenstraße 1, 14109 Berlin"}],["$","p",null,{"className":"text-sm text-amber-50 mb-4","children":"Bus 118, 218, 316 | Haltestelle Pfaueninselchaussee/Königstr. | ca. 800m Fußweg"}],["$","a",null,{"href":"https://www.google.com/maps/place/Lindenstra%C3%9Fe+1,+14109+Berlin/@52.4247729,13.154347,17z/data=!4m6!3m5!1s0x47a858eeccbab2db:0x107a68b11e611c0b!8m2!3d52.4251623!4d13.1541646!16s%2Fg%2F11c4kfrxmr?entry=ttu","target":"_blank","rel":"noopener noreferrer","children":["$","button",null,{"className":"inline-flex items-center justify-center whitespace-nowrap rounded-sm text-sm font-medium ring-offset-background transition-colors focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:pointer-events-none disabled:opacity-50 text-primary underline-offset-4 hover:underline h-10 px-4 py-2","ref":"$undefined","children":"Google Maps"}]}]]}]]}]
