2d:{"metadata":[["$","title","0",{"children":"Musikfest Wannsee"}],["$","meta","1",{"name":"description","content":"Das Musikfestival für Lied, Kammer- und Vokalmusik am Wannsee"}]],"error":null,"digest":"$undefined"}
